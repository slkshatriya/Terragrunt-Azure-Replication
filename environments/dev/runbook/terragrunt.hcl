include "root" {
  path = find_in_parent_folders()
}

locals {
  env_vars = read_terragrunt_config(find_in_parent_folders("env.hcl"))
  version  = read_terragrunt_config(find_in_parent_folders("version.hcl"))
}

terraform {
  source = local.version.locals.module_version == "local" ? "../../../modules/runbook" : "git::https://github.com/slkshatriya/Terragrunt-Azure-Replication.git//modules/runbook?ref=${local.version.locals.module_version}"
}

dependency "resource_group" {
  config_path = "../resource-group"
  mock_outputs = {
    resource_group_name     = "mock-rg"
    resource_group_location = "eastus"
  }
}

dependency "automation_account" {
  config_path = "../automation-account"
  mock_outputs = {
    automation_account_name = "mock-automation"
  }
}

inputs = {
  runbook_name            = "Get-ServicesScript"
  location                = dependency.resource_group.outputs.resource_group_location
  resource_group_name     = dependency.resource_group.outputs.resource_group_name
  automation_account_name = dependency.automation_account.outputs.automation_account_name
  runbook_type            = "PowerShell"
  log_verbose             = false
  log_progress            = false
  description             = null
  tags                    = local.env_vars.locals.tags

  # Content matches the ACTUAL runbook in Azure
  runbook_content = <<-EOT
        $svc = Get-Services
        Write-Output $svc
    EOT
}
